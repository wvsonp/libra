# Copy to .env and fill in values.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.1

# ── Loop guardrails
MAX_PLAN_TASKS=12
MAX_ITERATIONS=30
MAX_TOOL_CALLS_PER_TASK=4
TASK_TIMEOUT_SECONDS=60

# ── Search
# Number of DuckDuckGo results to fetch per query
SEARCH_MAX_RESULTS=5
# Seconds to wait between DDG retries (rate-limit back-off)
SEARCH_RETRY_DELAY=2.0
